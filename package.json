{
  "name": "hotel-booking-backend",
  "version": "1.0.0",
  "description": "MERN Online Hotel Booking System Backend",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "npm run dev --prefix HotelBookingWebsite",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "data:import": "node utils/seeder.js",
    "data:destroy": "node utils/seeder.js -d"
  },
  "keywords": [
    "mern",
    "hotel-booking",
    "nodejs",
    "express",
    "mongodb"
  ],
  "author": "Karan Garmora",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.13",
    "stripe": "^15.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
